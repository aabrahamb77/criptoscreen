# Copia este archivo a ".env" y completa con tus credenciales.
# Sin estas variables la app funciona igual, solo sin esas funciones extra.

# Turso (https://turso.tech → Create Database → Database URL + Auth Token).
# Sin esto: la app funciona igual, solo sin respaldo del historial en servidor.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Anthropic API (https://console.anthropic.com → API Keys).
# Sin esto: el botón "Explicar con IA" en Seguimiento queda desactivado.
ANTHROPIC_API_KEY=

# Token opcional para proteger los endpoints /api/* si expones el server fuera
# de localhost (exige "Authorization: Bearer <token>"). Vacío = sin auth.
API_TOKEN=

# Bot de paper trading: LXR_BOT=1 lo arranca junto al server.
# LXR_WARMUP_SEC = cobertura mínima del WS (segundos) antes de abrir posiciones.
LXR_BOT=
LXR_WARMUP_SEC=

# Grabación de order flow en Turso para backtests (necesita Turso configurado).
# LXR_RECORD=1 activa; FLOW_BUCKET_SEC = tamaño del bucket de CVD (15s por
# defecto); FLOW_RETENTION_DAYS = días que se conservan los datos (14).
LXR_RECORD=
FLOW_BUCKET_SEC=
FLOW_RETENTION_DAYS=